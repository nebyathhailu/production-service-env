  "source": {
    "type": "CODEPIPELINE",
    "buildspec": "buildspecs/dispatch-service.yml"
  },
  "artifacts": {
    "type": "CODEPIPELINE"
  },
  "environment": {
    "type": "LINUX_CONTAINER",
