{
  "family": "devops-g1-dispatch-service",
  "requiresCompatibilities": ["FARGATE"],
  "networkMode": "awsvpc",
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::827478161993:role/devops-g1-ecs-execution-role",
  "taskRoleArn": "arn:aws:iam::827478161993:role/devops-g1-ecs-task-role",
  "containerDefinitions": [
    {
      "name": "dispatch-service",
      "image": "827478161993.dkr.ecr.us-east-1.amazonaws.com/devops-g1-dispatch-service:5134ca0",
      "essential": true,
      "portMappings": [
        {
          "name": "dispatch-service",
          "containerPort": 3003,
          "protocol": "tcp",
          "appProtocol": "http"
        }
      ],
      "environment": [
        { "name": "DISPATCH_SERVICE_PORT", "value": "3003" },
        { "name": "BIND_HOST", "value": "0.0.0.0" },
        { "name": "RIDE_API_URL", "value": "http://ride-api:3001" },
        { "name": "DOWNSTREAM_TIMEOUT", "value": "5" }
      ],
      "healthCheck": {
        "command": ["CMD-SHELL", "curl -fs http://localhost:3003/health || exit 1"],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 10
      },
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/devops-g1-dispatch-service",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
