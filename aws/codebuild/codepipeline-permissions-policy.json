{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ArtifactBucket",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject",
        "s3:GetBucketVersioning"
      ],
      "Resource": [
        "arn:aws:s3:::devops-g1-pipeline-artifacts",
        "arn:aws:s3:::devops-g1-pipeline-artifacts/*"
      ]
    },
    {
      "Sid": "CodeConnectionsSource",
      "Effect": "Allow",
      "Action": "codeconnections:UseConnection",
      "Resource": "arn:aws:codeconnections:us-east-1:827478161993:connection/5fe9c0fb-8146-4afc-9d74-018bd3a86313"
    },
    {
      "Sid": "InvokeCodeBuild",
      "Effect": "Allow",
      "Action": [
        "codebuild:BatchGetBuilds",
        "codebuild:StartBuild"
      ],
      "Resource": "arn:aws:codebuild:us-east-1:827478161993:project/devops-g1-ride-api-build"
    },
    {
      "Sid": "EcsDeploy",
      "Effect": "Allow",
      "Action": [
        "ecs:DescribeServices",
        "ecs:DescribeTaskDefinition",
        "ecs:RegisterTaskDefinition",
        "ecs:UpdateService"
      ],
      "Resource": "*"
    },
    {
      "Sid": "PassEcsRoles",
      "Effect": "Allow",
      "Action": "iam:PassRole",
      "Resource": [
        "arn:aws:iam::827478161993:role/devops-g1-ecs-execution-role",
        "arn:aws:iam::827478161993:role/devops-g1-ride-api-task-role"
      ]
    }
  ]
}
