# Copy this file to .env and fill in real values before deploying.
# cp .env.example .env

# --- Docker Hub / image identity (used by docker-compose.prod.yml and scripts/deploy.sh) ---
DOCKERHUB_USERNAME=your-dockerhub-username
APP_NAME=production-service-env
IMAGE_TAG=sha-0000000

# --- Service runtime configuration (already defaulted in docker-compose.yml for local dev) ---
BIND_HOST=0.0.0.0
RIDE_API_PORT=3001
MATCHING_SERVICE_PORT=3002
DISPATCH_SERVICE_PORT=3003
DOWNSTREAM_TIMEOUT=5

# --- Observability stack (docker-compose.yml) ---
# Change this before running anywhere beyond your own machine - defaults to
# Grafana's own well-known default ("admin") if unset, which is fine for a
# local lab environment but should not be relied on elsewhere.
GRAFANA_ADMIN_PASSWORD=admin
