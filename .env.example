# Copy this file to .env and fill in real values before deploying.
# cp .env.example .env

# --- Docker Hub / image identity (used by docker-compose.prod.yml and scripts/deploy.sh) ---
DOCKERHUB_USERNAME=your-dockerhub-username
APP_NAME=production-service-env
IMAGE_TAG=sha-0000000

# --- Service runtime configuration (already defaulted in docker-compose.yml for local dev) ---
BIND_HOST=0.0.0.0
SERVICE_A_PORT=3001
SERVICE_B_PORT=3002
SERVICE_C_PORT=3003
DOWNSTREAM_TIMEOUT=5
